# Server environment variables
# Copy this file to .env and fill in real values — never commit .env to source control

# ── Authentication ─────────────────────────────────────────────────
# Secret key used to sign and verify JWTs (use a long, random string in production)
JWT_SECRET=your_jwt_secret_here

# ── AI APIs ────────────────────────────────────────────────────────
# Groq API key (used for summarization and chat — get one at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key (optional, if using Gemini instead of Groq)
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ───────────────────────────────────────────────────────
# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/ai-notes-summarizer
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/studychat-ai?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/ai-notes-summarizer

# ── CORS ───────────────────────────────────────────────────────────
# Allowed frontend origin (set this to your Vercel URL in production)
# Example: https://studychat-ai.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ── Server Port ────────────────────────────────────────────────────
# Only used for local development — Vercel ignores this
PORT=3001
