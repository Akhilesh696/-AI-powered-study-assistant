# Client environment variables
# Copy this file to .env and fill in real values — never commit .env to source control
# Vite exposes only variables prefixed with VITE_ to the browser bundle

# ── Local Development ──────────────────────────────────────────────
# Base URL of the Express API server (for local dev only)
VITE_API_URL=http://localhost:3001

# ── Vercel Production ──────────────────────────────────────────────
# On Vercel, the frontend and backend share the same domain, so leave VITE_API_URL empty.
# The client will automatically use relative /api/* paths.
# VITE_API_URL=